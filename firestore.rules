rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir leitura e escrita em usuarios para qualquer um (desenvolvimento)
    match /usuarios/{document=**} {
      allow read, write: if true;
    }

    // Permitir leitura e escrita em agendamentos para qualquer um (desenvolvimento)
    match /agendamentos/{document=**} {
      allow read, write: if true;
    }

    // Fallback para qualquer outra coleção
    match /{document=**} {
      allow read, write: if true;
    }
  }
}